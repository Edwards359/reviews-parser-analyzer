POSTGRES_DB=reviews_db
POSTGRES_USER=reviews_user
POSTGRES_PASSWORD=reviews_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
APP_HOST=0.0.0.0
APP_PORT=8000

# Должен быть случайной строкой длиной >= 16.
# Для локального запуска можно временно выставить ALLOW_INSECURE_TOKEN=true.
WORKER_API_TOKEN=please-change-me-to-random-long-value
ALLOW_INSECURE_TOKEN=false

# Куда слать уведомление о новом отзыве (worker). Если пусто — не шлём.
WEBHOOK_TARGET_URL=
WEBHOOK_TIMEOUT_SECONDS=5

PUBLIC_RATE_LIMIT_PER_MINUTE=30
ENVIRONMENT=local
