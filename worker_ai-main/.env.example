TARGET_SITE_URL=http://127.0.0.1:8000
WORKER_API_TOKEN=please-change-me-to-random-long-value
WORKER_POLL_INTERVAL=10
STATE_FILE_PATH=data/state.json
# Ограничение на размер state.json (чтобы не рос бесконечно).
# 0 в любом из параметров отключает соответствующее ограничение.
STATE_MAX_ENTRIES=10000
STATE_MAX_AGE_DAYS=30
AI_AUTHOR_NAME=AI Support

# openai | gigachat | yandex | fallback
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17

GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat

YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite

TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=

ENABLE_WEBHOOK=true
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8100
